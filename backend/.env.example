# 服务器配置
NODE_ENV=development
PORT=4000
HOST=localhost
CORS_ORIGIN=http://localhost:3000

# 安全配置
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
SESSION_SECRET=your-session-secret-change-this

# 数据库配置
DATABASE_URL=sqlite://./data/collaboration.db
DATABASE_PATH=./data/collaboration.db
DATABASE_MIGRATIONS_PATH=./migrations

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 文件存储
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain,text/markdown

# 邮件配置 (可选)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@aicollab.com

# 监控配置
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# 限流配置
RATE_LIMIT_WINDOW_MS=900000 # 15分钟
RATE_LIMIT_MAX_REQUESTS=100

# WebSocket配置
WS_PATH=/socket.io
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000
WS_MAX_HTTP_BUFFER_SIZE=1e6

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=10485760 # 10MB
LOG_MAX_FILES=30

# AI配置
AI_AGENT_COUNT=4
AI_MAX_CONCURRENT_TASKS=3
AI_TASK_TIMEOUT_MS=300000 # 5分钟

# 调试配置
DEBUG=ai-collaboration:*
DEBUG_COLORS=true